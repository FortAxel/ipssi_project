# Environment configuration for Storybook Kids (Docker + Symfony backend)
#
# Copy this file to .env and fill required values:
#   cp .env.example .env
#
# Then start the stack:
#   docker compose up -d --build
#
# Authoritative reference: docker-compose.yml, backend/config/packages/

# =====================================================
# Runtime
# =====================================================

# Symfony environment: prod | dev
# prod — full app on APP_PORT (built SPA in nginx, no npm required)
# dev  — Symfony debug; optional hot-reload: cd frontend && npm run dev (port 5173)
# After changing APP_ENV: docker compose up -d --build
APP_ENV=prod

# Symfony debug flag: 0 | 1
APP_DEBUG=0

# HTTP port exposed on the host for the full application (nginx)
# Default: 8080
APP_PORT=8080

# phpMyAdmin port on the host (database admin — dev data inspection, prod moderation)
# Default: 8081
PHPMYADMIN_PORT=8081

# Public base URL of the API (Symfony routing / CLI)
# Keep in sync with APP_PORT
DEFAULT_URI=http://localhost:8080

# Symfony secret (32+ random characters in production)
APP_SECRET=change_me_to_a_random_32_char_string

# =====================================================
# Database (MySQL)
# =====================================================

# MySQL root password (container bootstrap)
MYSQL_ROOT_PASSWORD=root

# Application database name
MYSQL_DATABASE=storybook

# Application database user
MYSQL_USER=storybook

# Application database password
# Must match the password in DATABASE_URL below
MYSQL_PASSWORD=storybook

# MySQL port exposed on the host (external clients, DBeaver, etc.)
# Default: 3307
MYSQL_PORT=3307

# Doctrine connection string (used inside Docker network)
# Host must be "mysql" (Docker service name), not 127.0.0.1
# Format: mysql://USER:PASSWORD@mysql:3306/DB_NAME?serverVersion=8.0&charset=utf8mb4
DATABASE_URL=mysql://storybook:storybook@mysql:3306/storybook?serverVersion=8.0&charset=utf8mb4

# =====================================================
# Authentication (JWT)
# =====================================================

# Key pair paths (generated on first boot by app-init if missing)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# Passphrase for the JWT private key
# Do not change after first boot unless you regenerate keys:
#   docker compose exec php php bin/console lexik:jwt:generate-keypair --overwrite --no-interaction --env=prod
JWT_PASSPHRASE=change_me_jwt_passphrase

# =====================================================
# CORS
# =====================================================

# Allowed Origin regex (Nelmio CORS)
# Default covers localhost and 127.0.0.1 on any port (SPA + Vite dev server)
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$

# =====================================================
# Text-to-speech (Microsoft Edge TTS)
# =====================================================

# 1 = enabled, 0 = disabled (falls back to browser Web Speech API)
TTS_ENABLED=1

# Provider identifier (edge only in this project)
TTS_PROVIDER=edge

# Voice ID — French child-friendly default
TTS_VOICE=fr-FR-EloiseNeural

# Speech rate / volume / pitch (edge-tts syntax)
TTS_RATE=-5%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz

# Max characters per synthesis request
TTS_MAX_CHARS=3000

# CLI binary name (installed in the PHP Docker image)
TTS_BINARY=edge-tts
