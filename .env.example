# Copy to backend/.env after clone (required — file is gitignored):
#   cp .env.example backend/.env
#
# Docker Compose overrides DATABASE_URL and TTS_* inside containers.
# Optional local overrides: backend/.env.local

APP_ENV=dev
APP_SECRET=change_me_to_a_random_32_char_string
DEFAULT_URI=http://localhost

DATABASE_URL=mysql://storybook:storybook@127.0.0.1:3307/storybook?serverVersion=8.0&charset=utf8mb4

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase

CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$

TTS_ENABLED=1
TTS_PROVIDER=edge
TTS_VOICE=fr-FR-EloiseNeural
TTS_RATE=-5%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz
TTS_MAX_CHARS=3000
TTS_BINARY=edge-tts
