# Modèle de configuration — vous n’avez PAS besoin de copier ce fichier à la racine.
#
# Pourquoi l’app fonctionne sans .env à la racine :
# - Symfony charge déjà backend/.env (valeurs par défaut + JWT, CORS, etc.)
# - Docker Compose injecte DATABASE_URL et TTS_* dans les conteneurs php / app-init
#   (ces variables d’environnement priment sur backend/.env)
#
# Copiez plutôt vers backend/.env.local pour des overrides locaux (non versionné).

APP_ENV=dev
APP_SECRET=change_me_to_a_random_32_char_string

DATABASE_URL=mysql://storybook:storybook@127.0.0.1:3307/storybook?serverVersion=8.0

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase

CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$

# --- TTS (API externe gratuite : Microsoft Edge, via CLI edge-tts dans Docker) ---
# Activer : TTS_ENABLED=1 puis docker compose up -d --build (installe edge-tts)
# Voix françaises « chaleureuses » : fr-FR-EloiseNeural, fr-FR-DeniseNeural, fr-FR-HenriNeural
TTS_ENABLED=0
TTS_PROVIDER=edge
TTS_VOICE=fr-FR-EloiseNeural
TTS_RATE=-5%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz
TTS_MAX_CHARS=3000
TTS_BINARY=edge-tts

# Comptes démo (fixtures) : parent@demo.local / parent123 — admin@demo.local / admin123
